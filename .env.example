# --- LLM FLEET CONFIGURATION (DEEP RESILIENCE MULTI-PROJECT GEMINI) ---

# Gemini Project A (PLANNER Focus - 4 Levels of Failover)
GEMINI_PROJECT_A_API_KEY=your_gemini_key_a_here
PROJECT_A_LEVEL_1_MODEL=gemini-1.5-pro
PROJECT_A_LEVEL_2_MODEL=gemini-1.5-flash
PROJECT_A_LEVEL_3_MODEL=gemini-1.5-flash-8b
PROJECT_A_LEVEL_4_MODEL=gemma-2-9b-it

# Gemini Project B (REASONER Focus - 4 Levels of Failover)
GEMINI_PROJECT_B_API_KEY=your_gemini_key_b_here
PROJECT_B_LEVEL_1_MODEL=gemini-1.5-flash
PROJECT_B_LEVEL_2_MODEL=gemini-1.5-pro
PROJECT_B_LEVEL_3_MODEL=gemini-1.5-flash-8b
PROJECT_B_LEVEL_4_MODEL=gemma-2-9b-it

# Gemini Project C (JUDGING Focus - 4 Levels of Failover)
GEMINI_PROJECT_C_API_KEY=your_gemini_key_c_here
PROJECT_C_LEVEL_1_MODEL=gemini-1.5-flash
PROJECT_C_LEVEL_2_MODEL=gemini-1.5-pro
PROJECT_C_LEVEL_3_MODEL=gemini-1.5-flash-8b
PROJECT_C_LEVEL_4_MODEL=gemma-2-9b-it

# OpenRouter Global Fallback (Automatic Free Routing)
OPENROUTER_API_KEY=your_openrouter_key_here
GLOBAL_FALLBACK_MODEL=openrouter/auto

# Redis Cloud Agent Memory (Context Engine)
REDIS_AGENT_MEMORY_URL=your-memory-url-here
REDIS_AGENT_MEMORY_KEY=your_cloud_key_here
REDIS_AGENT_MEMORY_STORE_ID=your_store_id_here

# --- STORAGE & INFRASTRUCTURE ---

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
DB_HOST=postgres

# --- MCP SERVER CONFIGURATION (Optional) ---

# GitHub MCP
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here

# Tavily Search MCP
TAVILY_API_KEY=your_tavily_api_key_here
