# --- LLM FLEET CONFIGURATION ---

# Primary Provider (Default: Groq)
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=gsk_your_groq_key_here
PLANNING_MODEL=llama-3.1-70b-versatile
REASONING_MODEL=llama-3.1-8b-instant

# Fallback Provider (Default: OpenAI)
FALLBACK_OPENAI_API_KEY=sk-proj-your-openai-key-here

# --- STORAGE & INFRASTRUCTURE ---

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_password_here
POSTGRES_DB=postgres
DB_HOST=localhost

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# --- MCP SERVER CONFIGURATION (Optional) ---

# GitHub MCP
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here

# Slack MCP
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Brave Search MCP
BRAVE_API_KEY=your_brave_api_key_here

# Notion MCP
NOTION_API_KEY=your_notion_api_key_here

# MCP Server Sidecar URLs (internal docker network URLs or localhost)
MCP_POSTGRES_URL=http://localhost:8081/sse
MCP_GITHUB_URL=http://localhost:8082/sse
MCP_PUPPETEER_URL=http://localhost:8083/sse
MCP_BRAVE_SEARCH_URL=http://localhost:8084/sse
MCP_SLACK_URL=http://localhost:8085/sse
MCP_NOTION_URL=http://localhost:8086/sse
