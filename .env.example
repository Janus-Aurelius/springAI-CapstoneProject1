# Main LLM Provider Configuration (Supports OpenAI, Groq, DeepSeek, etc.)
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com
PLANNING_MODEL=gpt-4o
REASONING_MODEL=gpt-4o-mini

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_password_here
POSTGRES_DB=postgres

# GitHub MCP Configuration
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here

# Slack MCP Configuration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Serper / Brave Search MCP Configuration
BRAVE_API_KEY=your_brave_api_key_here

# Notion MCP Configuration
NOTION_API_KEY=your_notion_api_key_here

# MCP Server Sidecar URLs (internal docker network URLs)
MCP_POSTGRES_URL=http://mcp-postgres:8081/sse
MCP_GITHUB_URL=http://mcp-github:8082/sse
MCP_PUPPETEER_URL=http://mcp-puppeteer:8083/sse
MCP_BRAVE_SEARCH_URL=http://mcp-brave-search:8084/sse
MCP_SLACK_URL=http://mcp-slack:8085/sse
MCP_NOTION_URL=http://mcp-notion:8086/sse
